{
	"Version": "2012-10-17",
	"Statement": [
		{
			"Effect": "Allow",
			"Action": [
				"s3:ListBucket"
			],
			"Resource": [
				"arn:aws:s3:::bucket",
				"arn:aws:s3:::bucket"
			]
		},
		{
			"Effect": "Allow",
			"Action": [
				"s3:PutObject",
				"s3:GetObject",
				"s3:DeleteObject",
				"s3:PutObjectAcl",
				"s3:PutObjectTagging"
			],
			"Resource": [
				"arn:aws:s3:::bucket/*",
				"arn:aws:s3:::bucket/*"
			]
		}
	]
}
